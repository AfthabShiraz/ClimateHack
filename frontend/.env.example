# Copy to .env and fill in. The app runs without these (falls back to a basic globe),
# but the photorealistic London map needs at least the Cesium Ion token.

# Cesium Ion — free, no credit card. https://ion.cesium.com  (Access Tokens)
VITE_CESIUM_ION_TOKEN=

# Google Photorealistic 3D Tiles — needs a Google Cloud key with the "Map Tiles API"
# enabled + billing on the project. Leave blank to use the free Cesium OSM Buildings fallback.
VITE_GOOGLE_MAPS_KEY=

# Backend (later milestones). Frontend uses seed data until this exists.
VITE_BACKEND_URL=http://localhost:8000
