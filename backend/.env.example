# Crosssight backend config — copy to backend/.env (gitignored). See README.md §8.

# --- agent layer ---
ANTHROPIC_API_KEY=

# --- live feeds (B3) ---
METOFFICE_API_KEY=          # heat + wind (Global Spot free tier); LAQN/DEFRA are keyless open data
METOFFICE_DAILY_CAP=300     # hard cap on Met Office calls/day (free tier = 360); never exceeded
LIVE_DATA=false             # false => all-synthetic (offline)
DEMO_MODE=false             # true => serve pre-baked briefs (data/alerts.json) — no live Anthropic call
SEED=1337                   # one seed drives every synthetic generator
REFRESH_SECONDS=300         # polite poll cadence; UI heartbeat is separate

# --- agent ACT / email dispatch (B5) ---
DISPATCH_ENABLED=false      # false => dry-run: log only, never send a real email
GMAIL_USER=                 # sender Gmail address
GMAIL_APP_PASSWORD=         # 16-char Gmail app password (NOT your account password)
DISPATCH_TO=zcabas5@ucl.ac.uk    # demo inbox — both supervisor alert + patient batch land here

# --- server ---
CORS_ORIGINS=http://localhost:5173
